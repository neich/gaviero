{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "gaviero",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_definition"
      }
    },
    "_definition": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "client_declaration"
        },
        {
          "type": "SYMBOL",
          "name": "agent_declaration"
        },
        {
          "type": "SYMBOL",
          "name": "workflow_declaration"
        }
      ]
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "//"
          },
          {
            "type": "PATTERN",
            "value": ".*"
          }
        ]
      }
    },
    "client_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "client"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "client_field"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "client_field": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "tier"
            },
            {
              "type": "SYMBOL",
              "name": "tier_value"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "model"
            },
            {
              "type": "SYMBOL",
              "name": "_string_value"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "privacy"
            },
            {
              "type": "SYMBOL",
              "name": "privacy_value"
            }
          ]
        }
      ]
    },
    "agent_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "agent"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "agent_field"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "agent_field": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "description"
            },
            {
              "type": "SYMBOL",
              "name": "_string_value"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "client"
            },
            {
              "type": "SYMBOL",
              "name": "identifier"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "scope_block"
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "depends_on"
            },
            {
              "type": "SYMBOL",
              "name": "identifier_list"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "prompt"
            },
            {
              "type": "SYMBOL",
              "name": "_string_value"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "max_retries"
            },
            {
              "type": "SYMBOL",
              "name": "integer"
            }
          ]
        }
      ]
    },
    "scope_block": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "scope"
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "scope_field"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "scope_field": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "owned"
            },
            {
              "type": "SYMBOL",
              "name": "string_list"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "read_only"
            },
            {
              "type": "SYMBOL",
              "name": "string_list"
            }
          ]
        }
      ]
    },
    "workflow_declaration": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "workflow"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "workflow_field"
          }
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "workflow_field": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "steps"
            },
            {
              "type": "SYMBOL",
              "name": "identifier_list"
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "max_parallel"
            },
            {
              "type": "SYMBOL",
              "name": "integer"
            }
          ]
        }
      ]
    },
    "string_list": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "_string_value"
          }
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "identifier_list": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "identifier"
          }
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "tier_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "coordinator"
        },
        {
          "type": "STRING",
          "value": "reasoning"
        },
        {
          "type": "STRING",
          "value": "execution"
        },
        {
          "type": "STRING",
          "value": "mechanical"
        }
      ]
    },
    "privacy_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "public"
        },
        {
          "type": "STRING",
          "value": "local_only"
        }
      ]
    },
    "_string_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "raw_string"
        }
      ]
    },
    "string": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "\""
          },
          {
            "type": "PATTERN",
            "value": "[^\"]*"
          },
          {
            "type": "STRING",
            "value": "\""
          }
        ]
      }
    },
    "raw_string": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "#\""
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[^\"\\n]"
                },
                {
                  "type": "PATTERN",
                  "value": "\\n"
                },
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "STRING",
                      "value": "\""
                    },
                    {
                      "type": "PATTERN",
                      "value": "[^#\\n]"
                    }
                  ]
                },
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "STRING",
                      "value": "\""
                    },
                    {
                      "type": "PATTERN",
                      "value": "\\n"
                    }
                  ]
                }
              ]
            }
          },
          {
            "type": "STRING",
            "value": "\"#"
          }
        ]
      }
    },
    "integer": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[0-9]+"
      }
    },
    "identifier": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[a-zA-Z_][a-zA-Z0-9_-]*"
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    },
    {
      "type": "SYMBOL",
      "name": "comment"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": []
}
