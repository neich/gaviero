{
  "files": {
    "exclude": {
      ".DS_Store": true,
      ".cache": true,
      ".gradle": true,
      ".idea": true,
      ".mvn": true,
      ".mypy_cache": true,
      ".next": true,
      ".nuxt": true,
      ".parcel-cache": true,
      ".pytest_cache": true,
      ".tox": true,
      ".venv": true,
      "Thumbs.db": true,
      "__pycache__": true,
      "build": true,
      "coverage": true,
      "dist": true,
      "node_modules": true,
      "out": true,
      "target": true,
      "venv": true
    }
  },
  "git": {
    "treeAllowList": [
      "config",
      "description",
      "HEAD",
      "hooks",
      "info"
    ]
  },
  "memory": {
    "namespace": "tree-sitter-gaviero",
    "readNamespaces": []
  },
  "panels": {
    "fileTree": {
      "width": 25
    },
    "layouts": {
      "1": [
        15,
        60,
        25
      ],
      "2": [
        15,
        40,
        45
      ],
      "3": [
        0,
        100,
        0
      ],
      "4": [
        0,
        60,
        40
      ]
    },
    "sidePanel": {
      "width": 50
    }
  }
}