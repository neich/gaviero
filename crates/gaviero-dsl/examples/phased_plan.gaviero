// Template: Execute a multi-phase implementation plan with dynamic phase extraction
//
// Shape:
//   analyse_plan (opus)              — extracts phases from the plan (resume-aware)
//     ↓
//   loop {
//     phase_executor (opus)          — runs phase {{ITER}} from the briefing
//     phase_gate     (sonnet)        — runs cargo check/test, writes verdict,
//                                      appends to execution journal
//     until agent phase_judge        — sonnet: "all briefing phases done?"
//     max_iterations 12              — safety cap; actual count comes from briefing
//   }
//     ↓
//   final_audit  (opus)              — cross-phase integration audit
//
// Why this shape: the DSL DAG is static at compile time, but the number of
// phases only becomes known after analyse_plan reads the plan document.
// A loop with a judge expresses "run one phase per iteration until the
// briefing is exhausted" without the script committing to a phase count.
//
// Tiers:
//   * analyse_plan, phase_executor, final_audit — expensive. Each does real
//     reasoning: extracting structure, executing a phase, cross-checking.
//   * phase_gate, phase_judge — cheap. Pattern-match on structured markers
//     (VERDICT: lines, phase counts), no deep reasoning.
//
// Hard-fail mechanism:
//   * phase_gate runs mechanical verification (`cargo check`, targeted
//     `cargo test`) BEFORE emitting its verdict. Failed builds produce
//     `VERDICT: STOP: <failing command>` automatically — no prose argument.
//   * On STOP, phase_judge exits the loop; phase_executor's STEP 0 halt
//     check also refuses to run the next phase if it ever fires.
//   * Workflow-level `verify { compile … test … }` is the final safety net
//     at end-of-run.
//
// Recovery (re-run same OUT_DIR after a crash or interruption):
//   Every phase writes a single entry to {{OUT_DIR}}/01-journal.md of the
//   form `## Phase N — <title>\nStatus: DONE|HALTED|FAILED\n…`. On re-run:
//     * analyse_plan sees {{OUT_DIR}}/00-briefing.md already exists and
//       reuses it verbatim (no regeneration).
//     * phase_executor's STEP 0 checks the journal for
//       `Phase {{ITER}}: DONE` and skips, writing a `RESUMED_SKIP` record.
//     * The loop walks forward to the first not-yet-DONE phase and resumes.
//   Recovery is "re-run with the same --var OUT_DIR". No CLI flag needed.
//
// Scope tradeoff vs. a hardcoded-phases version:
//   A single phase_executor runs every iteration, so its `owned` must cover
//   every file any phase could touch (e.g. `crates/` in a workspace, or
//   `src/` + `tests/` in a single-crate repo). You lose the per-phase
//   partition safety a hand-authored flat script would give you. If the
//   plan is big enough that you want per-phase ownership, fork this script
//   and hardcode the phase agents instead.
//
// Usage:
//   gaviero-cli --script phased_plan.gaviero \
//               --prompt-file /path/to/your/plan.md \
//               --var OUT_DIR=plans/log
//
// OUT_DIR is the single knob for where logs, briefings, and audits land.
// Both prompts and scope paths substitute {{OUT_DIR}} at compile time, so
// a single --var override relocates every output the script produces.

client opus {
    tier expensive
    model "claude-opus-4-7"
    effort high
    extra {
        // analyse_plan, phase_executor, and final_audit all do multi-document
        // synthesis — request a larger extended-thinking budget so Opus can
        // reason over the full plan + prior phase logs without running out.
        // Backends that don't consume the key ignore it (logged at debug).
        "thinking_budget" "8000"
    }
}

// `default` covers agents that don't declare `tier` or `client` explicitly.
// Every agent in this script sets a tier, so this is purely defensive —
// a misspelled `tier expensive` in a fork would fall back to sonnet rather
// than trigger the "no client declared" warning + haiku default.
client sonnet {
    tier cheap
    model "claude-sonnet-4-6"
    effort medium
    default
}

tier expensive opus
tier cheap     sonnet

vars {
    OUT_DIR "plans/log"
}

// ── Prompts ──────────────────────────────────────────────────────────────────

prompt analyse-body #"
    You are extracting an execution briefing from an implementation plan.

    STEP 0 — resume check.
      If {{OUT_DIR}}/00-briefing.md already exists AND its last line is
      `VERDICT: PROCEED`, this is a resumed run. Do NOT regenerate the
      briefing (it is the contract the downstream phases depend on).
      Exit without modifying any files. The existing briefing stands; the
      loop will walk forward from the first not-yet-DONE phase based on
      {{OUT_DIR}}/01-journal.md.

      Otherwise, proceed with the steps below to produce a fresh briefing.

    The implementation plan (passed via --prompt-file):

    {{PROMPT}}

    Skim CLAUDE.md and ARCHITECTURE.md for project conventions. Code
    in this repo lives under `crates/<crate>/src/`, not a top-level `src/`.

    Produce {{OUT_DIR}}/00-briefing.md with this exact structure:

        # Briefing

        PHASE_COUNT: <integer>

        ## Phase 1 — <short title>
        Goal: <one paragraph>
        Files to touch: <bullet list>
        Acceptance criteria: <numbered list>
        Depends on: <earlier phase numbers or "none">

        ## Phase 2 — <short title>
        ...

        (repeat for every phase the plan contains)

        ## Cross-phase notes
        - Ordering constraints
        - Known risks
        - Ambiguities or gaps in the plan — flag them, do NOT paper over

        VERDICT: PROCEED

    The `PHASE_COUNT` line is machine-read by the judge. Be exact.
    Each phase heading must be `## Phase <N> — <title>`, numbered from 1.

    If the plan is incoherent, self-contradictory, or missing a critical
    phase, replace the final line with:

        VERDICT: STOP: <one paragraph naming the gap>

    Downstream phases refuse to run if the briefing STOPs.
"#

prompt phase-body #"
    You are the phase executor. This is iteration {{ITER}}.

    STEP 0 — halt + resume check.
      a) Read {{OUT_DIR}}/00-briefing.md. If its last line is
         `VERDICT: STOP: …` or if iteration {{ITER}} is greater than
         PHASE_COUNT, write a single line to {{OUT_DIR}}/phase-{{ITER}}.md:

             HALTED: nothing to execute (briefing STOP or phase count exceeded)

         and exit without modifying any source files.

      b) If {{ITER}} > 1, read {{OUT_DIR}}/gate-{{PREV_ITER}}.md. If its
         last line is `VERDICT: STOP: …`, write:

             HALTED: <quote the STOP reason verbatim>

         to {{OUT_DIR}}/phase-{{ITER}}.md and exit.

      c) Resume check. If {{OUT_DIR}}/01-journal.md exists AND contains a
         `## Phase {{ITER}}` section whose `Status:` line reads `DONE`,
         this phase already completed in a prior run. Write to
         {{OUT_DIR}}/phase-{{ITER}}.md:

             RESUMED_SKIP: Phase {{ITER}} already DONE per journal

         and exit without modifying any source files. The loop advances
         to the next iteration. This is the recovery mechanism — re-running
         with the same --var OUT_DIR picks up at the first not-DONE phase.

    STEP 1 — locate your phase.
      From {{OUT_DIR}}/00-briefing.md, read the section headed
      `## Phase {{ITER}} — …`. That is your execution target for this
      iteration. If {{ITER}} > 1, also read every {{OUT_DIR}}/gate-*.md
      file so far — their DISCOVERIES sections are the channel through
      which earlier phases tell you their assumptions changed. Skip the
      full phase-*.md logs; the gate summary is enough.

    STEP 2 — execute the phase.
      Follow the phase's goal, file list, and acceptance criteria literally.
      Rules:
        - Touch only the files the briefing lists for Phase {{ITER}}. If the
          list is wrong, stop and record a DISCOVERY (see STEP 3) rather than
          widening scope silently.
        - Follow the plan's API choices exactly; do not redesign.
        - Run targeted `cargo check` / `cargo test` as you go.

    STEP 3 — write {{OUT_DIR}}/phase-{{ITER}}.md with:
        - Phase number and title (copied from briefing)
        - Files modified (list)
        - Acceptance criteria — status (met | partial | not met)
        - Deferred items and why
        - DISCOVERIES: anything this phase learned that casts doubt on later
          phases — be explicit. The gate reads this section to decide.
"#

prompt gate-body #"
    You are the gate after phase {{ITER}}. Do NOT modify source files.
    Your job is mechanical verification + verdict + journal append.

    STEP 0 — propagate HALT / RESUMED_SKIP.
      Read {{OUT_DIR}}/phase-{{ITER}}.md. If its first line starts with
      `HALTED:` or `RESUMED_SKIP:`:
        - Write {{OUT_DIR}}/gate-{{ITER}}.md containing (on one line,
          verbatim, no extra commentary after it):

              VERDICT: PASS

          (PASS because a SKIP is not a failure — the journal already
          records the prior DONE status; HALTED cases are detected by the
          judge via gate-{{PREV_ITER}}'s original STOP.) You MAY include
          prose above the VERDICT line; the verdict line itself must be
          the last line, exactly `VERDICT: PASS`.
        - Append to {{OUT_DIR}}/01-journal.md one entry (see STEP 4) with
          Status: SKIPPED or HALTED as appropriate, then exit.

    STEP 1 — mechanical verification.
      Run, in order, and capture the exit status of each:
        1. `cargo check --workspace` (or the project's equivalent build
           command per CLAUDE.md).
        2. `cargo clippy --workspace -- -D warnings` (same caveat).
        3. Targeted `cargo test` — derive the test selector from the
           briefing's Phase {{ITER}} "Acceptance criteria" or from the
           files listed under "Files to touch" (e.g.
           `cargo test -p <crate-of-touched-file> <module::path>`).
      If any command fails, the gate verdict is STOP; record the first
      failing command verbatim in the reason.

    STEP 2 — prose review.
      Read:
        - {{OUT_DIR}}/phase-{{ITER}}.md (especially DISCOVERIES)
        - The git diff for files modified in this phase
        - {{OUT_DIR}}/00-briefing.md — phase {{ITER}}'s acceptance criteria

      Additional STOP triggers beyond mechanical failure:
        - A DISCOVERY invalidates a later phase's plan (wrong API assumption,
          missing dependency, scope expanded beyond the briefing).
        - Acceptance criteria are materially unmet and retrying won't help —
          the plan is wrong, not the implementation.
        - Files outside the phase's declared file list were modified.

    STEP 3 — write {{OUT_DIR}}/gate-{{ITER}}.md with:
        - The three mechanical-verification commands and their exit status.
        - The prose review findings (one paragraph).
        - End with exactly one of:
              VERDICT: PASS
              VERDICT: STOP: <one-paragraph reason>

    STEP 4 — append to {{OUT_DIR}}/01-journal.md.
      If the journal does not yet exist, create it with a `# Execution
      Journal` heading. Append this exact block (no embellishment):

          ## Phase {{ITER}} — <phase title from briefing>
          Status: DONE | HALTED | SKIPPED | FAILED
          Verdict: PASS | STOP
          Commands: cargo check=<ok|fail>, cargo clippy=<ok|fail>, cargo test=<ok|fail>
          Touched: <comma-separated file list>
          Notes: <one line — DISCOVERY summary or "clean">

      Status values:
        - DONE      — verification passed and verdict is PASS.
        - SKIPPED   — RESUMED_SKIP was propagated; phase had completed earlier.
        - HALTED    — upstream STOP propagated (briefing or prior gate).
        - FAILED    — verdict is STOP for this phase's own work.

      The journal is the recovery contract: phase_executor.STEP 0 reads
      it on the next run to decide whether to skip. Keep entries terse,
      one block per phase, appended in iteration order.
"#

prompt judge-body #"
    You decide whether the phased run is complete.

    {{ITER_EVIDENCE}}

    Read:
      - {{OUT_DIR}}/00-briefing.md — parse the `PHASE_COUNT: <N>` line
      - {{OUT_DIR}}/gate-{{ITER}}.md — the latest gate verdict

    Return PASS (loop exits) when ANY of:
      1. Iteration {{ITER}} equals PHASE_COUNT AND the latest gate ends with
         `VERDICT: PASS`. All phases completed cleanly.
      2. The latest gate ends with `VERDICT: STOP: …`. The run is halted by
         policy; final_audit will report the halt.
      3. The briefing itself ended with `VERDICT: STOP:`. There is no work
         to do.

    Return FAIL (loop continues) when more phases remain and the latest
    gate PASSed — the next iteration should run Phase {{ITER}}+1.

    Output format — emit exactly one fenced JSON object as your last output:

    ```json
    {"verdict": "pass" | "fail", "reason": "<one short paragraph>"}
    ```
"#

prompt audit-body #"
    Final integration audit across every phase that ran.

    Read:
      - {{OUT_DIR}}/00-briefing.md
      - {{OUT_DIR}}/01-journal.md — the per-phase DONE/SKIPPED/HALTED/FAILED
        ledger. Start here: it is the canonical summary of what happened.
      - Every {{OUT_DIR}}/phase-*.md and {{OUT_DIR}}/gate-*.md
      - The full git diff vs the pre-swarm SHA (via tooling)

    Write {{OUT_DIR}}/99-audit.md covering:
      - Scope: did each phase deliver what the briefing promised?
        Cross-reference the journal's Status column.
      - Cross-phase: regressions or inconsistencies introduced late that
        earlier phases assumed weren't there.
      - API: does the public surface match the plan's stated API exactly?
      - Tests: are the promised tests real and passing? Note any phase
        whose journal entry shows `cargo test=fail`.
      - Halts / Skips: if any phase HALTED, SKIPPED, or FAILED, explain
        what remains undone and how to resume.
      - Follow-ups: anything deferred for a future run.

    End with one of:

        VERDICT: ACCEPT — merge as-is
        VERDICT: REJECT — <reason + which phase to re-run>
        VERDICT: HALTED — <which phase halted and why + resume instructions>
"#

// ── Agents ───────────────────────────────────────────────────────────────────

agent analyse_plan {
    description "Extract phases from plan: {{PROMPT}}"
    tier expensive
    scope {
        owned     ["{{OUT_DIR}}/00-briefing.md"]
        read_only ["crates/" "Cargo.toml" "CLAUDE.md" "ARCHITECTURE.md"]
    }
    prompt analyse-body
    max_retries 1

    memory {
        read_ns    ["architecture" "phase-history"]
        read_query "multi-phase implementation risks for {{PROMPT}}"
        read_limit 10
    }
}

// Single generic executor — runs once per loop iteration and picks its
// phase from the briefing using {{ITER}}. Broad `owned` scope is the
// cost of not hardcoding phases; the validator allows overlap here
// because phase_executor and phase_gate share the same loop group.
agent phase_executor {
    description "Execute phase {{ITER}} from briefing"
    tier expensive
    depends_on [analyse_plan]
    scope {
        owned     ["crates/" "{{OUT_DIR}}/phase-*.md"]
        read_only ["{{OUT_DIR}}/" "Cargo.toml" "ARCHITECTURE.md" "CLAUDE.md"]
    }
    prompt phase-body
    max_retries 2
}

agent phase_gate {
    description "Gate verdict after phase {{ITER}}"
    tier cheap
    depends_on [phase_executor]
    scope {
        owned     ["{{OUT_DIR}}/gate-*.md" "{{OUT_DIR}}/01-journal.md"]
        read_only ["{{OUT_DIR}}/" "crates/"]
    }
    prompt gate-body
    max_retries 1

    context { depth 0 }
    memory { read_limit 0 }
}

agent phase_judge {
    description "Judge whether all briefing phases are done"
    tier cheap
    scope {
        read_only ["{{OUT_DIR}}/"]
    }
    prompt judge-body

    context { depth 0 }
    memory { read_limit 0 }
}

agent final_audit {
    description "Final integration audit: {{PROMPT}}"
    tier expensive
    depends_on [phase_gate]
    scope {
        owned     ["{{OUT_DIR}}/99-audit.md"]
        read_only ["{{OUT_DIR}}/" "crates/" "Cargo.toml"]
    }
    prompt audit-body
    max_retries 1

    memory {
        write_ns      "phase-history"
        importance    0.9
        write_content #"
            Multi-phase execution — {{PROMPT}}
            Audit: {{SUMMARY}}
        "#
        staleness_sources ["crates/"]
    }
}

// ── Workflow ─────────────────────────────────────────────────────────────────
//
// max_iterations 12 is a safety cap, not a phase count. The judge exits the
// loop as soon as iteration {{ITER}} equals the briefing's PHASE_COUNT (or
// a gate STOPs). If your plan genuinely has more than ~10 phases, raise
// this — or reconsider whether the plan should be split.
//
// stability 1 because the judge's pass/fail is deterministic (reading a
// counter and a verdict line), not a vibes-based "converged?" judgment.
// No need to re-confirm.

workflow phased_plan {
    steps [
        analyse_plan
        loop {
            agents         [phase_executor phase_gate]
            max_iterations 12
            stability      1
            judge_timeout  60
            strict_judge   true
            until agent    phase_judge
        }
        final_audit
    ]
    max_parallel 1
    verify { compile true clippy true test true }

    memory {
        read_ns  ["architecture" "phase-history"]
        write_ns "phase-history"
    }
}
