// Shared client profiles for example workflows.
//
// Model strings use the canonical `provider:model` form (validated at
// dispatch by gaviero-core). `tier` is omitted here: these examples bind
// agents to concrete clients by name (`client opus`). Add top-level
// `tier <alias> <client>` declarations when you want re-pointable routing.

client opus {
    model "claude:opus"
    privacy public
    effort max
    default
}

client sonnet {
    model "claude:sonnet"
    privacy public
    // The judge emits a short JSON verdict — no deep reasoning needed.
    effort medium
}

client codex-5-5 {
    model "codex:gpt-5.5"
    privacy public
    // xhigh would clamp to Codex's `high` — ask for high directly so the
    // intent is explicit.
    effort high
}

client codex-5-4 {
    model "codex:gpt-5.4"
    privacy public
    effort medium
}

client composer {
    model "cursor:composer-2.5"
    privacy public
    effort medium
}
