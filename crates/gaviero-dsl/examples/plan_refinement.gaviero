client opus {
    tier expensive
    model "claude-opus-4-6"
    privacy public
    default
}

client codex {
    tier expensive
    model "codex:gpt-5.4"
    privacy public
}

// ── Shared configuration ──────────────────────────────────────────────────────
//
// INIT_VER: the version written by the init phase; read by the first loop pass
// as PREV_ITER (iter_start 2 → PREV_ITER=1 on loop iteration 1).

vars {
    PLANS    "plans"
    INIT_VER "1"
}

// ── Prompts ───────────────────────────────────────────────────────────────────
//
// Two focused prompts: one for independent initial planning, one for
// cross-model synthesis.
//
//   Init agents:   MODEL_NAME set per-agent; writes v{{INIT_VER}}
//   Refine agents: MODEL_NAME + PEER_NAME set per-agent; reads v{{PREV_ITER}},
//                  writes v{{ITER}} — all injected by the DSL at runtime

prompt init-body #"
    You are producing an independent architecture plan for:

    {{PROMPT}}

    Think from first principles. Do NOT read any existing files in {{PLANS}}/.

    Cover all of the following:
    - Motivation and goals
    - Proposed architecture and component breakdown
    - Implementation steps (ordered, concrete)
    - Data structures and API surface
    - Risks and mitigations
    - Alternatives considered and why rejected

    Write your plan to {{PLANS}}/{{MODEL_NAME}}-plan-v{{INIT_VER}}.md using
    clear markdown with headings. Do not hedge — commit to a design.
"#

prompt refine-body #"
    You are iteratively refining an architecture plan for:

    {{PROMPT}}

    1. Read {{PLANS}}/{{MODEL_NAME}}-plan-v{{PREV_ITER}}.md and
       {{PLANS}}/{{PEER_NAME}}-plan-v{{PREV_ITER}}.md in full.
    2. Analyse the pair: what does each get right? What does each miss,
       oversimplify, or get wrong? Where do they conflict?
    3. Synthesise a new plan taking the strongest elements of both,
       resolving conflicts with explicit reasoning, and improving on both.
    4. Write your refined plan to {{PLANS}}/{{MODEL_NAME}}-plan-v{{ITER}}.md.
       Begin with a "## Synthesis Notes" section: the pair you read, what
       you adopted from each, what you changed or discarded.
    5. Write a concise summary (under 300 words) to
       {{PLANS}}/{{MODEL_NAME}}-summary-v{{ITER}}.md covering the main
       differences between the two v{{PREV_ITER}} plans and the key choices
       made in this version. Write it for a human skimming the evolution.
"#

// ── Agents ────────────────────────────────────────────────────────────────────

agent claude-init {
    vars { MODEL_NAME "claude" }
    description "Initial plan (Claude): {{PROMPT}}"
    client opus
    scope {
        owned ["plans/"]
    }
    prompt init-body
}

agent codex-init {
    vars { MODEL_NAME "codex" }
    description "Initial plan (Codex): {{PROMPT}}"
    client codex
    scope {
        owned ["plans/"]
    }
    prompt init-body
}

agent claude-refine {
    vars { MODEL_NAME "claude" PEER_NAME "codex" }
    description "Refine plan (Claude): {{PROMPT}}"
    client opus
    scope {
        owned     ["plans/"]
        read_only ["plans/"]
    }
    prompt refine-body
    memory {
        write_ns   "plan-evolution"
        importance 0.7
        write_content #"
            Claude refinement — feature: {{PROMPT}}
        "#
    }
}

agent codex-refine {
    vars { MODEL_NAME "codex" PEER_NAME "claude" }
    description "Refine plan (Codex): {{PROMPT}}"
    client codex
    scope {
        owned     ["plans/"]
        read_only ["plans/"]
    }
    prompt refine-body
    memory {
        write_ns   "plan-evolution"
        importance 0.7
        write_content #"
            Codex refinement — feature: {{PROMPT}}
        "#
    }
}

// ── Workflow ──────────────────────────────────────────────────────────────────
//
// Phase 1 (parallel): claude-init and codex-init each write an independent v1
// plan from first principles with no cross-reading.
//
// Phase 2 (loop x5, parallel): claude-refine and codex-refine run in parallel
// each iteration. Both read the previous pair (v{{PREV_ITER}}) and write a
// new synthesised plan (v{{ITER}}) plus a summary of choices made.
//
// iter_start 2: loop iteration 1 → ITER=2, PREV_ITER=1 (reads v1 init plans)
//               loop iteration 2 → ITER=3, PREV_ITER=2
//               ...
//               loop iteration 5 → ITER=6, PREV_ITER=5

workflow feature-plan-refinement {
    steps [
        claude-init
        codex-init
        loop {
            agents         [claude-refine codex-refine]
            max_iterations 5
            iter_start     2
            until command  "false"
        }
    ]
    max_parallel 2
    memory {
        write_ns "plan-evolution"
    }
}
