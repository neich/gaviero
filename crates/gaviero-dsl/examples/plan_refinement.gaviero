// Each provider exposes a different reasoning knob. The DSL captures them
// in a provider-neutral way:
//
//   * `effort` — shared vocabulary (off/auto/low/medium/high/xhigh/max).
//     Claude uses it as-is; Codex clamps xhigh/max down to its own `high`
//     ceiling (see the mapping in backend/codex.rs). Values a backend
//     doesn't recognise are silently ignored.
//
//   * `extra { ... }` — provider-specific pass-through. Each `k "v"` pair
//     reaches the backend verbatim. Codex forwards them as `-c k=v` to
//     `codex exec`; Claude logs unknown keys at `tracing::debug` level
//     (the key list it consumes is documented in backend/claude_code.rs).
//
// The refine phase is where the planners do the heavy lifting, so the two
// expensive profiles are tuned for deep reasoning; the cheap judge can stay
// light since its job is a structured pass/fail verdict.

client opus {
    tier expensive
    model "claude-opus-4-7"
    privacy public
    effort auto
    extra {
        // Request a larger extended-thinking budget for the deep-synthesis
        // refine pass. Claude will consume this once the backend promotes
        // the key; until then it is logged as "ignored" (see step 3 plan).
        "thinking_budget" "8000"
    }
    default
}

client codex {
    tier expensive
    model "codex:gpt-5.4"
    privacy public
    // xhigh would clamp to Codex's `high` — ask for high directly so the
    // intent is explicit.
    effort high
}

client sonnet {
    tier cheap
    model "claude-sonnet-4-6"
    privacy public
    // The judge emits a short JSON verdict — no deep reasoning needed.
    effort low
}

// ── Shared configuration ──────────────────────────────────────────────────────
//
// INIT_VER: the version written by the init phase; read by the first loop pass
// as PREV_ITER (iter_start 2 → PREV_ITER=1 on loop iteration 1).

vars {
    OUT_DIR  "plans"
    INIT_VER "1"
}

// ── Prompts ───────────────────────────────────────────────────────────────────
//
// Two focused prompts: one for independent initial planning, one for
// cross-model synthesis, and one for convergence judgment.
//
//   Init agents:   MODEL_NAME set per-agent; writes v{{INIT_VER}}
//   Refine agents: MODEL_NAME + PEER_NAME set per-agent; reads v{{PREV_ITER}},
//                  writes v{{ITER}} — all injected by the DSL at runtime
//   Judge agent:   reads v{{ITER}} (and optionally v{{PREV_ITER}}) and must
//                  emit `VERDICT: PASS` or `VERDICT: FAIL`

prompt init-body #"
    You are producing an independent architecture plan for:

    {{PROMPT}}

    Think from first principles. Do NOT read any existing files in {{OUT_DIR}}/.

    Cover all of the following:
    - Motivation and goals
    - Proposed architecture and component breakdown
    - Implementation steps (ordered, concrete)
    - Data structures and API surface
    - Risks and mitigations
    - Alternatives considered and why rejected
    - **Phase decomposition for automated execution.** Partition the work into
      phases sized to land as a single reviewable PR (not per-sub-step,
      not per-whole-tier). For each phase specify:
        * owned files / crates (what this phase writes),
        * read-only dependencies (what this phase must read),
        * concrete pass/fail acceptance signals (compile, clippy lint, named
          tests, grep regressions — prefer mechanical signals over prose),
        * entanglement: which earlier phases' decisions must remain visible
          to this phase's executor (drives whether prior-phase logs must be
          read in full or just the gate verdicts).
      Call out when two candidate phases share enough surface that they
      should be merged rather than split.
    - **Execution shape for `phased_plan.gaviero`.** Recommend either:
        (a) one `phased_plan.gaviero` loop invocation covering all phases, or
        (b) N separate invocations with a human review checkpoint between
            top-level items,
      and state the tradeoff explicitly (resume granularity, diff-review
      size, cross-phase entanglement, gate cost). If (a), specify the
      minimum `phase_executor.owned` scope union that the DSL needs
      (widening beyond the default template is a real cost — call it out).
      If (b), specify the natural split boundaries and what each invocation's
      `{{PROMPT}}` should carry.

    Write your plan to {{OUT_DIR}}/{{MODEL_NAME}}-init-v{{INIT_VER}}.md using
    clear markdown with headings. Do not hedge — commit to a design.
"#

prompt refine-body #"
    You are iteratively refining an architecture plan for:

    {{PROMPT}}

    The previous pair lives in either `-init-v1.md` (iteration 1) or
    `-refine-plan-v{{PREV_ITER}}.md` (later iterations). If `{{PREV_ITER}}` is
    `1`, read the `-init-v1.md` files; otherwise read the `-refine-plan-…`
    files.

    1. Read {{OUT_DIR}}/{{MODEL_NAME}}-init-v{{PREV_ITER}}.md (if it exists) or
       {{OUT_DIR}}/{{MODEL_NAME}}-refine-plan-v{{PREV_ITER}}.md, and the peer's
       equivalent {{OUT_DIR}}/{{PEER_NAME}}-…-v{{PREV_ITER}}.md, in full.
    2. Analyse the pair: what does each get right? What does each miss,
       oversimplify, or get wrong? Where do they conflict?
    3. Synthesise a new plan taking the strongest elements of both,
       resolving conflicts with explicit reasoning, and improving on both.
    4. Write your refined plan to
       {{OUT_DIR}}/{{MODEL_NAME}}-refine-plan-v{{ITER}}.md. Begin with a
       '## Synthesis Notes' section: the pair you read, what you adopted from
       each, what you changed or discarded.
       The refined plan MUST retain (or introduce, if absent from the pair)
       a '## Phase decomposition' section and an '## Execution shape' section
       as specified by the init-phase brief:
         - Phase decomposition: per-phase owned files/crates, read-only
           dependencies, mechanical pass/fail signals, and cross-phase
           entanglement notes.
         - Execution shape: single `phased_plan.gaviero` loop invocation vs
           N invocations with human checkpoints, with the tradeoff stated
           and the required scope / `{{PROMPT}}` structure spelled out.
       If the v{{PREV_ITER}} pair disagrees on these, resolve the conflict
       in Synthesis Notes and commit to one shape.
    5. Write a concise summary (under 300 words) to
       {{OUT_DIR}}/{{MODEL_NAME}}-refine-summary-v{{ITER}}.md covering the main
       differences between the two v{{PREV_ITER}} plans and the key choices
       made in this version. Write it for a human skimming the evolution.
"#

prompt judge-body #"
    You are deciding whether two independently refined architecture plans have
    converged for:

    {{PROMPT}}

    {{ITER_EVIDENCE}}

    The digest above lists what the refine agents actually changed this
    iteration. Use it to focus your reading — if a file is not listed there
    it did not change this pass.

    1. Read {{OUT_DIR}}/claude-refine-plan-v{{ITER}}.md and
       {{OUT_DIR}}/codex-refine-plan-v{{ITER}}.md in full.
    2. Read {{OUT_DIR}}/claude-refine-summary-v{{ITER}}.md and
       {{OUT_DIR}}/codex-refine-summary-v{{ITER}}.md.
    3. If useful, compare against v{{PREV_ITER}} to judge whether the latest
       changes are still material.
    4. Return PASS only if:
       - the two current plans agree on the core architecture and major
         implementation steps,
       - any remaining differences are low-impact editorial refinements,
       - the newest iteration made minor refinements rather than material
         design changes.
    5. Otherwise return FAIL.

    Output format — emit exactly one fenced JSON object as your last output:

    ```json
    {"verdict": "pass" | "fail", "reason": "<one short paragraph>"}
    ```

    A plain `VERDICT: PASS` / `VERDICT: FAIL` line is also accepted as a
    fallback, but the JSON form is preferred for machine-parseability.
"#

// ── Agents ────────────────────────────────────────────────────────────────────

// Ownership uses glob patterns so each phase/model pair owns a disjoint
// filename namespace inside `{{OUT_DIR}}/`:
//   {{OUT_DIR}}/<model>-init-v*.md
//   {{OUT_DIR}}/<model>-refine-plan-v*.md
//   {{OUT_DIR}}/<model>-refine-summary-v*.md
// The scope validator checks patterns for real overlap (see
// `gaviero_core::path_pattern`), so `claude-init-*` and `codex-init-*` are
// accepted, while collisions within a pattern are still flagged.

agent claude-init {
    vars { MODEL_NAME "claude" }
    description "Initial plan (Claude): {{PROMPT}}"
    client opus
    scope {
        owned ["{{OUT_DIR}}/claude-init-*.md"]
    }
    prompt init-body
}

agent codex-init {
    vars { MODEL_NAME "codex" }
    description "Initial plan (Codex): {{PROMPT}}"
    client codex
    scope {
        owned ["{{OUT_DIR}}/codex-init-*.md"]
    }
    prompt init-body
}

agent claude-refine {
    vars { MODEL_NAME "claude" PEER_NAME "codex" }
    description "Refine plan (Claude): {{PROMPT}}"
    client opus
    scope {
        owned     ["{{OUT_DIR}}/claude-refine-*.md"]
        read_only ["{{OUT_DIR}}/"]
    }
    prompt refine-body
    memory {
        write_ns   "plan-evolution"
        importance 0.7
        write_content #"
            Claude refinement — feature: {{PROMPT}}
        "#
    }
}

agent codex-refine {
    vars { MODEL_NAME "codex" PEER_NAME "claude" }
    description "Refine plan (Codex): {{PROMPT}}"
    client codex
    scope {
        owned     ["{{OUT_DIR}}/codex-refine-*.md"]
        read_only ["{{OUT_DIR}}/"]
    }
    prompt refine-body
    memory {
        write_ns   "plan-evolution"
        importance 0.7
        write_content #"
            Codex refinement — feature: {{PROMPT}}
        "#
    }
}

agent convergence-judge {
    description "Judge plan convergence: {{PROMPT}}"
    client sonnet
    scope {
        read_only ["{{OUT_DIR}}/"]
    }
    prompt judge-body
}

// ── Workflow ──────────────────────────────────────────────────────────────────
//
// Phase 1 (parallel): claude-init and codex-init each write an independent v1
// plan from first principles with no cross-reading.
//
// Phase 2 (loop up to x10): claude-refine and codex-refine repeatedly read the
// previous pair (v{{PREV_ITER}}) and write a new synthesised plan (v{{ITER}})
// plus a summary of choices made.
//
// After each pass, convergence-judge evaluates the latest pair. Judge-control
// knobs (all optional; shown here with explicit values for documentation):
//
//   stability 2      → require 2 consecutive PASS verdicts before exiting.
//                      A single PASS is treated as provisional: the refine
//                      agents run one more pass and the judge re-evaluates.
//                      This guards against a flaky "looks good" verdict on
//                      a plan that is still materially evolving.
//   judge_timeout 90 → hard cap each judge invocation at 90s (0 disables).
//   strict_judge true → unparseable judge output fails the iteration loudly
//                       instead of silently being treated as FAIL. The judge
//                       prompt above commits to a JSON-object verdict, so
//                       any drift is worth surfacing.
//
// The judge prompt also uses `{{ITER_EVIDENCE}}`: the runtime substitutes a
// bounded digest of the refine agents' most recent summaries and modified
// files so the judge can focus on what actually changed this pass.
//
// iter_start 2: loop iteration 1 → ITER=2, PREV_ITER=1 (reads v1 init plans)
//               loop iteration 2 → ITER=3, PREV_ITER=2
//               ...
//               loop iteration 10 → ITER=11, PREV_ITER=10

workflow feature-plan-refinement {
    steps [
        claude-init
        codex-init
        loop {
            agents         [claude-refine codex-refine]
            max_iterations 10
            iter_start     2
            stability      2
            judge_timeout  90
            strict_judge   true
            until agent    convergence-judge
        }
    ]
    max_parallel 2
    memory {
        write_ns "plan-evolution"
    }
}
